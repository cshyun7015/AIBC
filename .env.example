# Azure OpenAI Settings
AZURE_OPENAI_API_KEY=your_azure_openai_api_key_here
AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com/

# Optional Overrides (기본값은 코드 내에 설정되어 있음)
# AOAI_DEPLOY_GPT4O=aitl-prd-gpt-4o
# AOAI_DEPLOY_EMBED_3_SMALL=aitl-prd-text-embedding-3-small

# LLM Mocking 설정 (true 일 경우 API 호출 없이 Dummy 반환)
USE_MOCK_LLM=true
